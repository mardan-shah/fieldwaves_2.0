{
  "mcpServers": {
    "docs-scraper": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-docs-scraper"
      ]
    },
    
    "tailwind": {
      "command": "npx",
      "args": [
        "-y",
        "tailwindcss-mcp-server"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "shadcn@latest",
        "mcp"
      ]
    }
  }
}